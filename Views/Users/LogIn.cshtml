@{
    ViewBag.Title = "Log In";
    Layout = "_LayoutUsers";
}
<style>
    /* Estilos personalizados para el botón de búsqueda */
    #searchButton {
        position: fixed;
        top: 20px;
        left: 20px;
        font-size: 20px; /* Tamaño de fuente reducido */
        color: #fff; /* Color blanco */
        background-color: transparent; /* Fondo transparente */
        border: none; /* Sin borde */
        outline: none; /* Sin contorno al hacer clic */
        cursor: pointer;
    }

    .loginButton {
        background-color: #ffbade;
        color: #201f31;
    }

    /* Estilos para la imagen */
    .logo-img {
        max-width: 150px; /* Máximo ancho de la imagen */
        margin: 0 auto; /* Centrar horizontalmente */
        display: block; /* Hacer que la imagen sea un bloque */
    }
</style>

<!-- Botón de búsqueda -->
<button id="searchButton" class="btn rounded-button" type="submit">
    <i class="bi bi-arrow-left"></i>
</button>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <!-- Reducción del ancho del contenedor -->
            <div class="card">
                <div class="card-header">
                    <!-- Imagen -->
                    <img src="https://oyster.ignimgs.com/mediawiki/apis.ign.com/slime-rancher/6/6c/Pink_Slime_SP.png" class="logo-img" />
                    <h2 class="text-center">Hi again!!</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <!-- Campo de Correo Electrónico -->
                        <div class="mb-3">
                            <label for="inputEmail">Email</label>
                            <input type="email" name="email" class="form-control" id="inputEmail" placeholder="Enter your email" required>
                        </div>

                        <!-- Campo de Contraseña -->
                        <div class="mb-3">
                            <label for="inputPassword">Password</label>
                            <input type="password" name="password" class="form-control" id="inputPassword" placeholder="Enter your password" required>
                        </div>

                        <!-- Mensaje de Error -->
                        <h4 style="color:darkred">@ViewData["NOEXISTE"]</h4>

                        <div class="col-12 text-center">
                            <!-- Utilizamos la clase text-center aquí -->
                            <!-- Botón de Inicio de Sesión -->
                            <button type="submit" class="btn  col-12 loginButton">Log In</button>
                        </div>

                        <!-- Enlace para Crear Cuenta -->
                        <div class="mt-3 text-end">
                            <p>New here? <a asp-action="SignUp" asp-controller="Users">Create an account</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Event listener para el botón de búsqueda
    document.getElementById('searchButton').addEventListener('click', function () {
        history.back();
    });
</script>
